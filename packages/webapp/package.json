{
  "name": "webapp",
  "version": "0.0.0",
  "scripts": {
    "clean": "rm -rf .next",
    "dev:release-port": "sh -c 'for p in $(lsof -ti tcp:5002 2>/dev/null); do kill -9 \"$p\" 2>/dev/null; done; exit 0'",
    "predev": "pnpm run dev:release-port",
    "dev": "next dev -p 5002 --experimental-https --experimental-https-key ./certificates/adhoc-server.key --experimental-https-cert ./certificates/adhoc-server.crt --experimental-https-ca ./certificates/root_ca.crt",
    "dev:webpack": "pnpm run dev:release-port && next dev --webpack -p 5002 --experimental-https --experimental-https-key ./certificates/adhoc-server.key --experimental-https-cert ./certificates/adhoc-server.crt --experimental-https-ca ./certificates/root_ca.crt",
    "dev:turbo": "pnpm run dev:release-port && next dev --turbopack -p 5002 --experimental-https --experimental-https-key ./certificates/adhoc-server.key --experimental-https-cert ./certificates/adhoc-server.crt --experimental-https-ca ./certificates/root_ca.crt",
    "dev:oss": "pnpm run dev:release-port && NEXT_PUBLIC_API_URL=http://localhost:5000 NEXT_PUBLIC_DOMAIN=localhost next dev -p 5002",
    "dev:oss:turbo": "pnpm run dev:release-port && NEXT_PUBLIC_API_URL=http://localhost:5000 NEXT_PUBLIC_DOMAIN=localhost next dev --turbopack -p 5002",
    "dev:notls": "pnpm run dev:release-port && next dev -p 5002",
    "dev:notls:turbo": "pnpm run dev:release-port && next dev --turbopack -p 5002",
    "build": "next build",
    "build:turbo": "next build --turbopack",
    "build:notls": "NODE_TLS_REJECT_UNAUTHORIZED=0 pnpm run build",
    "start": "next start",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0 --fix",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "pretest": "npm run lint",
    "test": "jest --runInBand",
    "deploy": "vercel"
  },
  "prettier": "@dailydotdev/prettier-config",
  "dependencies": {
    "@dailydotdev/shared": "workspace:*",
    "@hookform/resolvers": "5.2.2",
    "@intercom/messenger-js-sdk": "^0.0.18",
    "@kickass-coderz/react": "^0.0.5",
    "@marsidev/react-turnstile": "1.1.0",
    "@paddle/paddle-js": "1.4.0",
    "@serwist/turbopack": "^9.5.7",
    "@tanstack/react-query": "^5.80.5",
    "@tanstack/react-query-devtools": "^5.80.5",
    "classnames": "^2.5.1",
    "date-fns": "^2.28.0",
    "date-fns-tz": "1.2.2",
    "dompurify": "^2.5.4",
    "fetch-event-stream": "^0.1.6",
    "focus-visible": "^5.2.1",
    "framer-motion": "^12.23.25",
    "graphql": "^16.9.0",
    "graphql-request": "^3.7.0",
    "idb-keyval": "^5.1.5",
    "jotai": "^2.12.2",
    "lottie-react": "^2.4.1",
    "next": "16.2.1",
    "next-seo": "^5.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-flip-toolkit": "^7.1.0",
    "react-hook-form": "7.54.2",
    "react-intersection-observer": "^8.34.0",
    "react-modal": "^3.16.3",
    "react-parallax-tilt": "^1.7.320",
    "react-swipeable": "^7.0.1",
    "serwist": "^9.5.7",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@dailydotdev/eslint-config": "workspace:*",
    "@dailydotdev/eslint-plugin-daily-dev-eslint-rules": "workspace:*",
    "@dailydotdev/prettier-config": "workspace:*",
    "@next/bundle-analyzer": "16.2.1",
    "@svgr/webpack": "^5.5.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/dompurify": "^2.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.1",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/react-modal": "^3.16.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.27",
    "babel-jest": "^29.7.0",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "esbuild": "^0.25.11",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-testing-library": "^7.16.1",
    "fake-indexeddb": "^3.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^12.3.0",
    "nock": "^13.2.4",
    "node-fetch": "^2.6.7",
    "postcss": "^8.5.8",
    "postcss-100vh-fix": "^1.0.2",
    "postcss-custom-media": "^11.0.3",
    "postcss-focus-visible": "^5.0.0",
    "postcss-import": "^16.1.1",
    "postcss-mixins": "^9.0.4",
    "postcss-nesting": "^13.0.0",
    "postcss-rem-to-responsive-pixel": "^6.0.2",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.4.14",
    "tailwindcss-safe-area": "0.8.0",
    "typescript": "5.6.3",
    "vercel": "^21.3.3"
  },
  "sideEffects": [
    "*.css"
  ]
}
